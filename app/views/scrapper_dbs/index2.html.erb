<div>
  <table class="scrapper_table">
    <thead>
      <tr>
        <th class="option_url">URL</th>
        <th class="option_meta">Meta Data</th>
        <th class="option_source">Source Provider</th>
        <th class="option_subtype">Sub Type</th>
        <th class="option_status">Status</th>
        <th class="option_response">Response</th>
      </tr>
    </thead>
    <tbody>
      <% @records.each do |db_record| %>
        <tr>
          <td class="option_url"><%= db_record.url %></td>
          <td class="option_meta"><%= db_record.meta_data %></td>
          <td class="option_source"><%= db_record.source_provider %></td>
          <td class="option_subtype"><%= db_record.sub_type %></td>
          <td class="option_status">done</td>
          <td class="option_response">
            <% if db_record.response.present? %>
              <span class="response-indicator" data-response='<%= db_record.response.to_json %>' onclick="showResponseModal(this)">✅</span>
            <% else %>
              NULL
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Modal for displaying JSON response -->
<div id="responseModal" class="modal">
  <div class="modal-content">
    <span class="close-button" onclick="closeResponseModal()">&times;</span>
    <h2>Response Data</h2>
    <div id="jsonTree"></div>
  </div>
</div>

<style>
.scrapper_table {
  width: 100%;
  table-layout: fixed;
  font-size: 0.875rem; /* Tailwind: text-sm */
  border: 1px solid #d1d5db; /* Tailwind: border-gray-300 */
  border-collapse: collapse;
}

.scrapper_table th,
.scrapper_table td {
  padding: 0.5rem; /* Tailwind: px-2 py-1 */
  border: 1px solid #e5e7eb; /* Tailwind: border-gray-200 */
  vertical-align: top;
}

/* Truncate URL to single line with ellipsis */
.option_url {
  width: 10%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Meta data: show 3 lines with ellipsis */
.option_meta {
  /* width: 25%; */
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Show full content for source and subtype */
.option_source,
.option_subtype {
  width: 20%;
  white-space: normal;
  word-wrap: break-word;
}

/* Status column - small */
.option_status {
  width: 8%;
  text-align: center;
}

/* Response - small and ellipsed */
.option_response {
  width: 10%;
  text-align: center;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* Response indicator styling */
.response-indicator {
  cursor: pointer;
}

/* Modal styles */
.modal {
  display: none;
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0,0,0,0.4);
}

.modal-content {
  background-color: #fefefe;
  margin: 5% auto;
  padding: 20px;
  border: 1px solid #888;
  width: 80%;
  max-width: 800px;
  max-height: 80vh;
  overflow: auto;
  border-radius: 5px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.close-button {
  color: #aaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
}

.close-button:hover,
.close-button:focus {
  color: black;
  text-decoration: none;
}

#jsonTree {
  margin-top: 15px;
  font-family: monospace;
  font-size: 14px;
}

/* JSON tree styling */
.json-key {
  color: #881391;
}
.json-value {
  color: #1A1AA6;
}
.json-string {
  color: #C41A16;
}
.json-boolean {
  color: #0000FF;
}
.json-null {
  color: #808080;
}

/* Mobile view: hide low-priority columns */
@media (max-width: 768px) {
  .option_url,
  .option_meta,
  .option_response {
    display: none;
  }
  
  .modal-content {
    width: 95%;
    margin: 10% auto;
  }
}
</style>

<script>
  function showResponseModal(element) {
    const modal = document.getElementById('responseModal');
    const jsonTree = document.getElementById('jsonTree');
    
    try {
      const responseData = JSON.parse(element.getAttribute('data-response'));
      jsonTree.innerHTML = formatJsonToHtml(responseData);
      modal.style.display = 'block';
    } catch (error) {
      console.error('Error parsing JSON:', error);
      jsonTree.innerHTML = '<div class="error">Error parsing JSON response</div>';
      modal.style.display = 'block';
    }
  }
  
  function closeResponseModal() {
    const modal = document.getElementById('responseModal');
    modal.style.display = 'none';
  }
  
  // Close modal when clicking outside of it
  window.onclick = function(event) {
    const modal = document.getElementById('responseModal');
    if (event.target === modal) {
      modal.style.display = 'none';
    }
  }
  
  function formatJsonToHtml(json, level = 0) {
    const indent = '  '.repeat(level);
    let html = '';
    
    if (Array.isArray(json)) {
      html += '<div class="json-array">[</div>';
      json.forEach((item, index) => {
        html += '<div style="padding-left: 20px;">';
        html += formatJsonToHtml(item, level + 1);
        if (index < json.length - 1) {
          html += ',';
        }
        html += '</div>';
      });
      html += '<div>]</div>';
    } else if (json !== null && typeof json === 'object') {
      html += '<div class="json-object">{</div>';
      const keys = Object.keys(json);
      keys.forEach((key, index) => {
        html += '<div style="padding-left: 20px;">';
        html += `<span class="json-key">"${key}"</span>: `;
        html += formatJsonToHtml(json[key], level + 1);
        if (index < keys.length - 1) {
          html += ',';
        }
        html += '</div>';
      });
      html += '<div>}</div>';
    } else if (typeof json === 'string') {
      html += `<span class="json-string">"${escapeHtml(json)}"</span>`;
    } else if (typeof json === 'number') {
      html += `<span class="json-value">${json}</span>`;
    } else if (typeof json === 'boolean') {
      html += `<span class="json-boolean">${json}</span>`;
    } else if (json === null) {
      html += `<span class="json-null">null</span>`;
    }
    
    return html;
  }
  
  function escapeHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }
</script>
