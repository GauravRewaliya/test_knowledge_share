<div id="responseModal" class="modal">
  <div class="modal-content">
    <span class="close-button" onclick="closeResponseModal()">&times;</span>
    <h2>Response Data</h2>
    <div id="jsonTree"></div>
  </div>
</div>
<style>

/* Modal styles */
.modal {
  display: none;
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: auto;
  background-color: rgba(0,0,0,0.4);
}

.modal-content {
  background-color: #fefefe;
  margin: 5% auto;
  padding: 20px;
  border: 1px solid #888;
  width: 80%;
  max-width: 800px;
  max-height: 80vh;
  overflow: auto;
  border-radius: 5px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.close-button {
  color: #aaa;
  float: right;
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
}

.close-button:hover,
.close-button:focus {
  color: black;
  text-decoration: none;
}

#jsonTree {
  margin-top: 15px;
  font-family: monospace;
  font-size: 14px;
}

/* JSON tree styling */
.json-key {
  color: #881391;
}
.json-value {
  color: #1A1AA6;
}
.json-string {
  color: #C41A16;
}
.json-boolean {
  color: #0000FF;
}
.json-null {
  color: #808080;
}
</style>
<script>
    
  function closeResponseModal() {
    const modal = document.getElementById('responseModal');
    modal.style.display = 'none';
  }
  
  // Close modal when clicking outside of it
  window.onclick = function(event) {
    const modal = document.getElementById('responseModal');
    if (event.target === modal) {
      modal.style.display = 'none';
    }
  }
  
  function formatJsonToHtml(json, level = 0) {
    const indent = '  '.repeat(level);
    let html = '';
    
    if (Array.isArray(json)) {
      html += '<div class="json-array">[</div>';
      json.forEach((item, index) => {
        html += '<div style="padding-left: 20px;">';
        html += formatJsonToHtml(item, level + 1);
        if (index < json.length - 1) {
          html += ',';
        }
        html += '</div>';
      });
      html += '<div>]</div>';
    } else if (json !== null && typeof json === 'object') {
      html += '<div class="json-object">{</div>';
      const keys = Object.keys(json);
      keys.forEach((key, index) => {
        html += '<div style="padding-left: 20px;">';
        html += `<span class="json-key">"${key}"</span>: `;
        html += formatJsonToHtml(json[key], level + 1);
        if (index < keys.length - 1) {
          html += ',';
        }
        html += '</div>';
      });
      html += '<div>}</div>';
    } else if (typeof json === 'string') {
      html += `<span class="json-string">"${escapeHtml(json)}"</span>`;
    } else if (typeof json === 'number') {
      html += `<span class="json-value">${json}</span>`;
    } else if (typeof json === 'boolean') {
      html += `<span class="json-boolean">${json}</span>`;
    } else if (json === null) {
      html += `<span class="json-null">null</span>`;
    }
    
    return html;
  }
  
  function escapeHtml(str) {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

</script>